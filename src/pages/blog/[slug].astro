---
// src/pages/blog/[slug].astro - SINGLE BLOG POST WITH FULL CONSISTENCY (Strapi v5-ready)
import MainLayout from '../../layouts/MainLayout.astro';
import { getBlogPost, getRelatedBlogPosts } from '../../lib/strapi';

export async function getStaticPaths() {
  // Dynamic routing; ścieżki generowane runtime
  return [];
}

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/blog');
}

// --- helpers: v5/v4 normalizacja ---
const pick = (obj: any, path: string[]) =>
  path.reduce((acc, key) => (acc && acc[key] != null ? acc[key] : undefined), obj);

const normImage = (img: any) => {
  const url =
    pick(img, ['url']) ??
    pick(img, ['data', 'attributes', 'url']) ??
    null;
  const alternativeText =
    pick(img, ['alternativeText']) ??
    pick(img, ['data', 'attributes', 'alternativeText']) ??
    '';
  return url ? { url, alternativeText } : null;
};

const normAuthor = (a: any) => ({
  name: pick(a, ['name']) ?? pick(a, ['data', 'attributes', 'name']) ?? 'Koordynuj Zdrowie',
  bio: pick(a, ['bio']) ?? pick(a, ['data', 'attributes', 'bio']) ?? ''
});

const normCategory = (c: any) => ({
  id: pick(c, ['id']) ?? pick(c, ['data', 'id']),
  name:
    (typeof c === 'string' ? c : undefined) ??
    pick(c, ['name']) ??
    pick(c, ['data', 'attributes', 'name']) ??
    'Artykuł',
  slug:
    pick(c, ['slug']) ??
    pick(c, ['data', 'attributes', 'slug']) ??
    'artykul'
});

const normTag = (t: any) =>
  t?.attributes ? { name: t.attributes.name } : { name: t?.name };

const normPost = (p: any) => {
  const a = p?.attributes ?? p; // v5: płasko, v4: w attributes
  return {
    id: p?.id ?? a?.id,
    slug: a?.slug,
    title: a?.title,
    excerpt: a?.excerpt,
    content: a?.content,
    publishedAt: a?.publishedAt ?? a?.createdAt,
    author: normAuthor(a?.author ?? {}),
    category: normCategory(a?.category ?? {}),
    featuredImage: normImage(a?.featuredImage),
    tags: Array.isArray(a?.tags) ? a.tags.map(normTag) : [],
    seo: a?.seo ?? {}
  };
};

// Fetch post data
const rawPost = await getBlogPost(slug);
if (!rawPost) {
  return Astro.redirect('/blog');
}
const post = normPost(rawPost);

// Get related posts (po kategorii jeśli dostępna)
const relatedRaw = await getRelatedBlogPosts(slug, post.category?.id);
const relatedPosts = Array.isArray(relatedRaw) ? relatedRaw.map(normPost) : [];

// SEO data
const title = post.seo?.metaTitle || `${post.title} | Koordynuj Zdrowie`;
const description = post.seo?.metaDescription || post.excerpt || "Blog o medycynie i zarządzaniu placówkami medycznymi";

// Helper functions (UI)
const formatDate = (dateString: string) =>
  new Date(dateString).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });

const createExcerpt = (content: string, length: number = 120) => {
  if (!content) return "";
  const plainText = content.replace(/<[^>]*>/g, '');
  return plainText.length > length ? plainText.substring(0, length) + '...' : plainText;
};
---

<MainLayout title={title} description={description}>
    
  <!-- Article Header -->
  <section class="py-20 sm:py-32 bg-background-light relative overflow-hidden" data-section="post-header">
    <!-- Subtle animated background pattern -->
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none">
      <div class="post-header-bg-pattern absolute inset-0"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumbs -->
      <nav class="mb-8" data-reveal="fade-up" data-reveal-delay="100">
        <ol class="flex items-center space-x-2 text-sm text-text-muted">
          <li><a href="/" class="hover:text-brand-blue transition-colors">Strona główna</a></li>
          <li class="before:content-['/'] before:mx-2 before:text-gray-400">
            <a href="/blog" class="hover:text-brand-blue transition-colors">Blog</a>
          </li>
          <li class="before:content-['/'] before:mx-2 before:text-gray-400">
            <span class="text-text-primary font-medium">{post.title}</span>
          </li>
        </ol>
      </nav>

      <!-- Article Meta -->
      <div class="mb-6" data-reveal="fade-up" data-reveal-delay="200">
        <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-gradient-to-br from-brand-blue to-brand-blue/80 rounded-full flex items-center justify-center mr-3">
              <span class="text-white text-sm font-bold">
                {post.author.name?.charAt(0) || "K"}
              </span>
            </div>
            <span class="font-medium">{post.author.name}</span>
          </div>
          <span>•</span>
          <time>{formatDate(post.publishedAt)}</time>
          <span>•</span>
          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-brand-blue/10 text-brand-blue">
            {post.category.name}
          </span>
        </div>
      </div>

      <!-- Article Title -->
      <div data-reveal="fade-up" data-reveal-delay="300">
        <h1 class="text-4xl md:text-6xl font-extrabold text-text-primary mb-6 tracking-tighter leading-tight">
          {post.title}
        </h1>
        
        {post.excerpt && (
          <p class="text-xl text-text-muted leading-relaxed">
            {post.excerpt}
          </p>
        )}
      </div>

      <!-- Featured Image -->
      {post.featuredImage?.url && (
        <div class="mt-12" data-reveal="slide-up-scale" data-reveal-delay="400">
          <div class="aspect-[16/9] rounded-2xl overflow-hidden shadow-xl">
            <img 
              src={post.featuredImage.url}
              alt={post.featuredImage.alternativeText || post.title}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Article Content -->
  <section class="py-16 bg-white" data-section="post-content">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" data-reveal="fade-up" data-reveal-delay="100">
        <!-- Article Content -->
        <div class="article-content">
          {post.content ? (
            <div set:html={post.content} />
          ) : (
            <p class="text-text-muted italic">
              Treść artykułu będzie dostępna po podłączeniu do systemu CMS.
            </p>
          )}
        </div>
        
        <!-- Article Tags -->
        {post.tags && post.tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-gray-200">
            <h3 class="text-sm font-medium text-text-muted mb-4">Tagi:</h3>
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag: { name: string }) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-text-muted">
                  #{tag.name}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Author Bio -->
      <div class="mt-16 p-8 bg-background-muted rounded-2xl" data-reveal="fade-up" data-reveal-delay="300">
        <div class="flex items-start space-x-4">
          <div class="w-16 h-16 bg-gradient-to-br from-brand-blue to-brand-blue/80 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-white text-xl font-bold">
              {post.author.name?.charAt(0) || "K"}
            </span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-text-primary mb-2">
              {post.author.name}
            </h3>
            <p class="text-text-muted">
              {post.author.bio || "Ekspert w dziedzinie zarządzania placówkami medycznymi i optymalizacji procesów zdrowotnych."}
            </p>
          </div>
        </div>
      </div>

      <!-- Back to Blog -->
      <div class="mt-12 text-center" data-reveal="fade-up" data-reveal-delay="400">
        <a href="/blog" class="btn-primary inline-flex items-center group">
          <svg class="mr-2 w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Powrót do bloga
        </a>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {relatedPosts && relatedPosts.length > 0 && (
    <section class="py-16 bg-background-muted" data-section="related-posts">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-reveal="fade-up" data-reveal-delay="100">
          <h2 class="text-3xl font-bold text-text-primary mb-4">
            Powiązane artykuły
          </h2>
          <p class="text-lg text-text-muted">
            Może Cię również zainteresować
          </p>
        </div>

        <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-8">
          {relatedPosts.slice(0, 3).map((rp, index) => (
            <article 
              class="blog-card group flex flex-col bg-white border border-slate-200/80 rounded-3xl shadow-sm transition-all duration-500 hover:border-brand-blue/50 hover:shadow-xl hover:shadow-brand-blue/10"
              data-reveal="slide-up-scale"
              data-reveal-delay={200 + (index * 100)}
            >
              <div class="aspect-[16/9] bg-gradient-to-br from-brand-blue/10 to-brand-blue/5 rounded-t-3xl overflow-hidden relative">
                {rp.featuredImage?.url ? (
                  <img 
                    src={rp.featuredImage.url}
                    alt={rp.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="w-12 h-12 text-brand-blue/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                  </div>
                )}
                
                <div class="absolute top-4 left-4">
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-brand-blue/90 text-white">
                    {rp.category.name}
                  </span>
                </div>
              </div>

              <div class="flex flex-col flex-grow p-6">
                <div class="flex items-center text-sm text-text-muted mb-3">
                  <span>{rp.author.name}</span>
                  <span class="mx-2">•</span>
                  <time>{formatDate(rp.publishedAt)}</time>
                </div>

                <h3 class="text-lg font-bold text-text-primary mb-3 group-hover:text-brand-blue/90 transition-colors duration-300 line-clamp-2">
                  {rp.title}
                </h3>

                <p class="text-text-muted leading-relaxed mb-4 flex-grow line-clamp-2">
                  {rp.excerpt || createExcerpt(rp.content || "")}
                </p>

                <a 
                  href={`/blog/${rp.slug}`}
                  class="inline-flex items-center text-brand-blue font-semibold mt-auto group-hover:translate-x-1 transition-transform duration-300"
                >
                  Czytaj więcej
                  <svg class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</MainLayout>

<style>
  /* === CONSISTENT REVEAL SYSTEM === */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  
  [data-reveal="slide-up-scale"] {
    opacity: 0;
    transform: translateY(30px) scale(0.95);
  }
  
  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }
  
  [data-reveal="slide-up-scale"].revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* === BLOG CARDS - IDENTICAL TO OTHER SECTIONS === */
  .blog-card { position: relative; cursor: pointer; }
  .blog-card::before {
    content: '';
    position: absolute; inset: 0; border-radius: 1.5rem;
    background: linear-gradient(135deg, rgba(0, 169, 224, 0.05), rgba(0, 169, 224, 0.02));
    opacity: 0; transition: opacity 0.5s ease;
  }
  .blog-card:hover::before { opacity: 1; }
  .blog-card:hover { transform: translateY(-4px); }

  /* === PROSE STYLING === */
  .prose { color: var(--color-text-primary); line-height: 1.8; }
  .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 { color: var(--color-text-primary); font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; }
  .prose h2 { font-size: 1.875rem; border-bottom: 2px solid var(--color-brand-blue); padding-bottom: 0.5rem; }
  .prose h3 { font-size: 1.5rem; color: var(--color-brand-blue); }
  .prose a { color: var(--color-brand-blue); font-weight: 500; text-decoration: underline; text-underline-offset: 4px; }
  .prose a:hover { color: var(--color-text-primary); }
  .prose blockquote {
    border-left: 4px solid var(--color-brand-blue);
    padding-left: 1.5rem; margin: 2rem 0; font-style: italic; color: var(--color-text-muted);
    background: var(--color-background-muted); padding: 1.5rem; border-radius: 0.5rem;
  }
  .prose ul, .prose ol { margin: 1.5rem 0; padding-left: 1.5rem; }
  .prose li { margin-bottom: 0.5rem; }

  /* === LINE CLAMP === */
  .line-clamp-2 {
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* === BACKGROUND PATTERN === */
  .post-header-bg-pattern {
    background-image: 
      radial-gradient(circle at 30% 30%, rgba(0, 169, 224, 0.06) 1px, transparent 1px),
      radial-gradient(circle at 70% 70%, rgba(0, 169, 224, 0.08) 1px, transparent 1px);
    background-size: 120px 120px, 180px 180px;
    animation: patternDrift 25s linear infinite;
  }

  @keyframes patternDrift {
    0% { background-position: 0% 0%, 0% 0%; }
    100% { background-position: 100% 100%, -100% 100%; }
  }

  /* === ACCESSIBILITY === */
  .no-js [data-reveal] { opacity: 1 !important; transform: none !important; }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal], .blog-card, .post-header-bg-pattern {
      animation: none !important; transition: none !important;
    }
    [data-reveal] { opacity: 1; transform: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('[data-section]');
    
    sections.forEach(section => {
      setTimeout(() => {
        const hiddenElements = section.querySelectorAll('[data-reveal]:not(.revealed)');
        hiddenElements.forEach(el => el.classList.add('revealed'));
      }, 2000);

      const revealElements = section.querySelectorAll('[data-reveal]');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = entry.target.getAttribute('data-reveal-delay') || '0';
            setTimeout(() => {
              entry.target.classList.add('revealed');
            }, parseInt(delay, 10));
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '-5%' });

      revealElements.forEach(el => revealObserver.observe(el));
    });
  });
</script>
