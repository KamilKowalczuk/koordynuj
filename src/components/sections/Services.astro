            <ul class="space-y-2">
                <li class="flex items-start"><span class="text-brand-blue mr-2">→</span> Przygotowanie i złożenie dokumentów rejestrowych</li>
                <li class="flex items-start"><span class="text-brand-blue mr-2">→</span> Wdrożenie kompletnej dokumentacji</li>
                <li class="flex items-start"><span class="text-brand-blue mr-2">→</span> Organizacja wszystkich współpracy i procedur</li>
                <li class="flex items-start"><span class="text-brand-blue mr-2">→</span> Bieżące wsparcie w pierwszych miesiącach</li>
            </ul>
        `
    }
];

// Transformujemy dane ze Strapi aby zachować kompatybilność z istniejącym kodem
const transformStrapiServices = (strapiServices: any[]) => {
    return strapiServices.map(service => ({
        id: service.id,
        title: service.title,
        shortDescription: service.shortDescription,
        icon: service.icon,
        // Używamy fullDescription jako whyWorthIt jeśli scope nie istnieje
        whyWorthIt: service.scope || service.fullDescription,
        scope: service.scope,
        benefits: service.benefits,
        collaborationModel: service.collaborationModel
    }));
};

// Używamy danych ze Strapi lub fallback
const services = servicesData && servicesData.length > 0 
    ? transformStrapiServices(servicesData) 
    : fallbackServices;
---

<section id="oferta" class="py-20 sm:py-32 bg-background-light relative overflow-hidden">
    <!-- Geometryczne tło sugerujące porządek -->
    <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" viewBox="0 0 1200 800">
            <defs>
                <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                    <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#00A9E0" stroke-width="0.5"/>
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid)" />
        </svg>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4">
        <!-- Nagłówek sekcji zgodny z briefem -->
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
                Nasze 4 filary. Twoja droga do porządku.
            </h2>
            <p class="text-lg text-text-muted max-w-3xl mx-auto">
                Kompleksowe rozwiązania, które przekształcą Twoją placówkę w nowoczesną, efektywną i prawnie bezpieczną organizację.
            </p>
        </div>

        <!-- Interaktywny grid usług -->
        <ServicesGrid {services} client:load />

        <!-- Wezwanie do działania -->
        <div class="text-center mt-16">
            <p class="text-lg text-text-muted mb-6">
                Gotowy na <span class="font-semibold text-brand-blue">transformację</span> swojej placówki?
            </p>
            <a href="#kontakt" class="btn-primary inline-flex items-center">
                Umów bezpłatną konsultację
                <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
        </div>
    </div>
</section>