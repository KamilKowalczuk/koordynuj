---
// src/components/layout/Footer.astro - WERSJA Z IDEALNYM WYRÓWNANIEM KOLUMN
import Logo from '../ui/Logo.astro';

const settings = {
    contactPhone: "535 604 904",
    contactEmail: "kontakt@koordynujzdrowie.pl",
    companyAddress: "ul. Zdrowa 1, 00-001 Warszawa"
};

const currentYear = new Date().getFullYear();
---
<footer class="bg-background-muted border-t border-slate-200/60">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 lg:items-start">

      <div class="flex flex-col items-center lg:items-start lg:flex-shrink-0 lg:col-span-4 text-center lg:text-left" style="line-height: 0px;font-size: 0px;">
        <a href="/" class="inline-block">
          <Logo isHomepage={false} />
        </a>
        <p class="mt-4 text-base text-text-muted max-w-sm mx-auto lg:mx-0">
          Podnosimy efektywność placówek medycznych, domykamy rozliczenia i dbamy o zgodność prawną. Uwalniamy Cię od chaosu.
        </p>
      </div>

      <div class="md:col-span-1 lg:col-span-2 text-center lg:text-left">
        <h3 class="font-semibold text-text-primary">Menu</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/#oferta" class="text-text-muted hover:text-brand-blue transition-colors">Oferta</a></li>
          <li><a href="/#casestudy" class="text-text-muted hover:text-brand-blue transition-colors">Case Study</a></li>
          <li><a href="/blog" class="text-text-muted hover:text-brand-blue transition-colors">Blog</a></li>
          <li><a href="/#kontakt" class="text-text-muted hover:text-brand-blue transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <div class="md:col-span-1 lg:col-span-2 text-center lg:text-left">
        <h3 class="font-semibold text-text-primary">Dokumenty</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/regulamin" class="text-text-muted hover:text-brand-blue transition-colors">Regulamin</a></li>
          <li><a href="/polityka-prywatnosci" class="text-text-muted hover:text-brand-blue transition-colors">Polityka Prywatności</a></li>
        </ul>
      </div>

      <div class="lg:col-span-4 text-center lg:text-left">
        <h3 class="font-semibold text-text-primary">Skontaktuj się z nami</h3>
        <address class="mt-4 space-y-3 not-italic">
          {settings.contactPhone && (
            <a href={`tel:${settings.contactPhone.replace(/\s/g, '')}`} class="flex items-center justify-center lg:justify-start gap-3 text-text-muted hover:text-brand-blue transition-colors">
              <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <span>{settings.contactPhone}</span>
            </a>
          )}
          {settings.contactEmail && (
            <a href={`mailto:${settings.contactEmail}`} class="flex items-center justify-center lg:justify-start gap-3 text-text-muted hover:text-brand-blue transition-colors">
              <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <span>{settings.contactEmail}</span>
            </a>
          )}
          <!-- {settings.companyAddress && (
            <p class="flex items-center justify-center lg:justify-start gap-3 text-text-muted">
              <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <span>{settings.companyAddress}</span>
            </p>
          )} -->
        </address>
      </div>

    </div>

    <div class="mt-16 pt-8 border-t border-slate-200/60 text-center text-sm text-text-muted">
      <p>&copy; {currentYear} Koordynuj Zdrowie. Wszystkie prawa zastrzeżone.</p>
    </div>

  </div>
</footer>