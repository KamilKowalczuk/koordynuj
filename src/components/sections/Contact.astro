---
// src/components/sections/Contact.astro - WERSJA PEŁNA I POPRAWIONA
import ContactForm from '../ui/ContactForm.svelte';
---

<section id="kontakt" class="py-20 sm:py-32 bg-background-muted relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" viewBox="0 0 1200 800">
            <g class="animate-convergence">
                <path d="M0,100 Q600,350 1200,200" stroke="#00A9E0" stroke-width="1" fill="none"/>
                <path d="M0,300 Q600,380 1200,400" stroke="#00A9E0" stroke-width="1" fill="none"/>
                <path d="M0,500 Q600,420 1200,600" stroke="#00A9E0" stroke-width="1" fill="none"/>
                <path d="M0,700 Q600,450 1200,800" stroke="#00A9E0" stroke-width="1" fill="none"/>
            </g>
            <circle cx="600" cy="400" r="3" fill="#00A9E0" opacity="0.4" class="animate-pulse-center"/>
        </svg>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4">
        <div class="text-center mb-12 animate-reveal">
            <h2 class="section-heading">
                Zacznijmy koordynować Twój sukces.
            </h2>
            <p class="section-subtitle">
                Wypełnij formularz, a nasz strateg skontaktuje się z Tobą w ciągu <span class="font-semibold text-brand-blue">24h</span>, aby umówić bezpłatną konsultację.
            </p>
        </div>

        <div class="max-w-2xl mx-auto animate-reveal" style="--reveal-delay: 200ms;">
            <ContactForm client:load />
        </div>

        <div class="text-center mt-16 animate-reveal" style="--reveal-delay: 400ms;">
            <p class="text-text-muted mb-6">Lub skontaktuj się z nami bezpośrednio:</p>
            <div class="flex flex-col sm:flex-row justify-center items-center space-y-4 sm:space-y-0 sm:space-x-8">
                <a href="tel:+48123456789" class="flex items-center text-brand-blue hover:text-brand-blue/80 transition-colors duration-300">
                    <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    +48 123 456 789
                </a>
                <a href="mailto:kontakt@koordynujzdrowie.pl" class="flex items-center text-brand-blue hover:text-brand-blue/80 transition-colors duration-300">
                    <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    kontakt@koordynujzdrowie.pl
                </a>
            </div>
        </div>
    </div>
</section>


<style>
    /* Style tła SVG (bez zmian) */
    @keyframes convergence {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-5px); }
    }
    @keyframes pulse-center {
        0%, 100% { opacity: 0.4; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.5); }
    }
    .animate-convergence { animation: convergence 10s ease-in-out infinite; }
    .animate-pulse-center { animation: pulse-center 3s ease-in-out infinite; }

    /* Spójna animacja wejścia */
    .animate-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        transition-delay: var(--reveal-delay, 0ms);
    }
    .animate-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    // Spójny IntersectionObserver
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.animate-reveal').forEach(el => {
            observer.observe(el);
        });
    });
</script>