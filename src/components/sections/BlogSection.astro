---
// src/components/sections/BlogSection.astro - UNIFIED ANIMATION
import AnimateOnScroll from '../ui/AnimateOnScroll.astro'; // Importujemy nasz system animacji
import { getBlogPosts } from '../../lib/strapi';

const blogPosts = await getBlogPosts(6);

const fallbackPosts = [
    {
        id: 1, slug: "nowe-przepisy-medyczne-2024", title: "Nowe przepisy medyczne w 2024 roku",
        excerpt: "Przegląd najważniejszych zmian prawnych, które wpływają na funkcjonowanie placówek medycznych.",
        publishedAt: "2024-01-15", author: { name: "Koordynuj Zdrowie", avatar: null },
        featuredImage: null, category: "Prawo medyczne"
    },
    {
        id: 2, slug: "optymalizacja-rozliczen", title: "Jak zoptymalizować rozliczenia NFZ",
        excerpt: "Praktyczne wskazówki dotyczące poprawy efektywności rozliczeń z Narodowym Funduszem Zdrowia.",
        publishedAt: "2024-01-10", author: { name: "Koordynuj Zdrowie", avatar: null },
        featuredImage: null, category: "Rozliczenia"
    },
    {
        id: 3, slug: "digitalizacja-placowki", title: "Digitalizacja placówki medycznej",
        excerpt: "Kompletny przewodnik po cyfrowej transformacji gabinetu lekarskiego.",
        publishedAt: "2024-01-05", author: { name: "Koordynuj Zdrowie", avatar: null },
        featuredImage: null, category: "Technologia"
    }
];

const posts = Array.isArray(blogPosts) && blogPosts.length > 0 ? blogPosts : fallbackPosts;

const formatDate = (dateString: string) => {
    const date = new Date(dateString);
    return date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
};

const createExcerpt = (content: string, length: number = 120) => {
    if (!content) return "";
    const plainText = content.replace(/<[^>]*>/g, '');
    return plainText.length > length ? plainText.substring(0, length) + '...' : plainText;
};
---

<section id="blog" class="py-20 sm:py-32 bg-background-light relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none">
        <div class="blog-bg-pattern absolute inset-0"></div>
    </div>

    <AnimateOnScroll>
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
                    Wiedza, która się opłaca.
                </h2>
                <p class="text-lg text-text-muted">
                    Praktyczne porady, aktualne przepisy i sprawdzone strategie dla placówek medycznych.
                </p>
            </div>

            <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-8 mb-12">
                {posts.map((post) => {
                    const author = post.author || { name: "Koordynuj Zdrowie" };
                    const category = typeof post.category === 'string' ? post.category : post.category?.name || "Artykuł";
                    
                    return (
                        <article class="blog-card group flex flex-col bg-white border border-slate-200/80 rounded-3xl shadow-sm transition-all duration-500 hover:border-brand-blue/50 hover:shadow-xl hover:shadow-brand-blue/10">
                            <div class="aspect-[16/9] bg-gradient-to-br from-brand-blue/10 to-brand-blue/5 rounded-t-3xl overflow-hidden relative">
                                {post.featuredImage?.url ? (
                                    <img src={post.featuredImage.url} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center">
                                        <svg class="w-16 h-16 text-brand-blue/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                    </div>
                                )}
                                <div class="absolute top-4 left-4">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-brand-blue/90 text-white">
                                        {category}
                                    </span>
                                </div>
                            </div>
                            <div class="flex flex-col flex-grow p-6">
                                <div class="flex items-center text-sm text-text-muted mb-3">
                                    
                                    <time>{formatDate(post.publishedAt ?? "")}</time>
                                </div>
                                <h3 class="text-xl font-bold text-text-primary mb-3 group-hover:text-brand-blue/90 transition-colors duration-300 line-clamp-2">
                                    {post.title}
                                </h3>
                                <p class="text-text-muted leading-relaxed mb-4 flex-grow line-clamp-3">
                                    {post.excerpt || "Przeczytaj więcej w pełnym artykule..."}
                                </p>
                                <a href={`/blog/${post.slug}`} class="inline-flex items-center text-brand-blue font-semibold mt-auto group-hover:translate-x-1 transition-transform duration-300">
                                    Czytaj więcej
                                    <svg class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                </a>
                            </div>
                        </article>
                    );
                })}
            </div>

            <div class="text-center">
                <p class="text-lg text-text-muted mb-6">
                    Chcesz być na bieżąco z <span class="font-semibold text-brand-blue">najnowszymi przepisami</span>?
                </p>
                <a href="/blog" class="btn-primary inline-flex items-center group">
                    Zobacz wszystkie artykuły
                    <svg class="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>
    </AnimateOnScroll>
</section>

<style>
    /* Usunięto style dla [data-reveal] */
    .blog-card {
        position: relative;
        cursor: pointer;
    }
    .blog-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 1.5rem;
        background: linear-gradient(135deg, rgba(0, 169, 224, 0.05), rgba(0, 169, 224, 0.02));
        opacity: 0;
        transition: opacity 0.5s ease;
    }
    .blog-card:hover::before {
        opacity: 1;
    }
    .blog-card:hover {
        transform: translateY(-4px);
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .blog-bg-pattern {
        background-image: 
            radial-gradient(circle at 20% 30%, rgba(0, 169, 224, 0.08) 1px, transparent 1px),
            radial-gradient(circle at 80% 70%, rgba(0, 169, 224, 0.06) 1px, transparent 1px),
            radial-gradient(circle at 50% 20%, rgba(0, 169, 224, 0.10) 1px, transparent 1px);
        background-size: 180px 180px, 220px 220px, 200px 200px;
        animation: patternDrift 35s linear infinite;
    }
    @keyframes patternDrift {
        0% { background-position: 0% 0%, 0% 0%, 0% 0%; }
        100% { background-position: 100% 100%, -100% 100%, 50% -100%; }
    }
    @media (prefers-reduced-motion: reduce) {
        .blog-card,
        .blog-bg-pattern {
            animation: none !important;
            transition: none !important;
        }
    }
    @media (max-width: 768px) {
        .blog-bg-pattern {
            display: none;
        }
    }
</style>