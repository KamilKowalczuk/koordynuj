---
// src/pages/blog/index.astro - BLOG MAIN PAGE WITH FULL CONSISTENCY - FIXED VERSION
import MainLayout from '../../layouts/MainLayout.astro';
import { getBlogPosts, getBlogCategories, getBlogPostsCount } from '../../lib/strapi';

// Pagination setup
const currentPage = 1;
const postsPerPage = 9;

// Fetch data
const [blogPosts, categories, totalPosts] = await Promise.all([
    getBlogPosts(postsPerPage, currentPage),
    getBlogCategories(),
    getBlogPostsCount()
]);

// Fallback data - WITH CORRECT TYPE STRUCTURE
const fallbackPosts = [
    {
        id: 1,
        slug: "optymalizacja-rozliczen-nfz-2024",
        title: "5 najczęstszych błędów w rozliczeniach NFZ i jak ich uniknąć",
        excerpt: "Praktyczny przewodnik po najważniejszych pułapkach w rozliczeniach z NFZ, które mogą kosztować Twoją placówkę tysiące złotych.",
        publishedAt: "2024-01-15",
        author: { name: "Dr Anna Kowalska" },
        category: { name: "Rozliczenia NFZ" },
        featuredImage: null // ADDED: Must exist in fallback type
    },
    {
        id: 2,
        slug: "rodo-w-praktyce-medycznej",
        title: "RODO w praktyce medycznej - kompletna lista dokumentów",
        excerpt: "Wszystkie dokumenty RODO potrzebne w gabinecie lekarskim w 2024 roku. Gotowe wzory do pobrania.",
        publishedAt: "2024-01-10",
        author: { name: "Mgr Piotr Nowak" },
        category: { name: "Prawo medyczne" },
        featuredImage: null // ADDED: Must exist in fallback type
    },
    {
        id: 3,
        slug: "digitalizacja-placowek-medycznych",
        title: "Digitalizacja placówek medycznych - krok po kroku",
        excerpt: "Praktyczny przewodnik wdrożenia systemów cyfrowych w gabinecie lekarskim. Od wyboru oprogramowania po szkolenie personelu.",
        publishedAt: "2024-01-08",
        author: { name: "Mgr Anna Technolog" },
        category: { name: "Technologia" },
        featuredImage: null // ADDED: Must exist in fallback type
    }
];

const posts = blogPosts && blogPosts.length > 0 ? blogPosts : fallbackPosts;
const totalPages = Math.ceil((totalPosts || fallbackPosts.length) / postsPerPage);

// Helper functions
const formatDate = (dateString: string) => {
    return new Date(dateString).toLocaleDateString('pl-PL', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric' 
    });
};

const createExcerpt = (content: string, length: number = 120) => {
    if (!content) return "";
    const plainText = content.replace(/<[^>]*>/g, '');
    return plainText.length > length ? plainText.substring(0, length) + '...' : plainText;
};
---

<MainLayout 
    title="Blog - Koordynuj Zdrowie | Wiedza o medycynie w praktyce"
    description="Praktyczne porady, aktualne przepisy i sprawdzone strategie dla placówek medycznych. Bądź na bieżąco z najnowszymi zmianami w systemie zdrowia."
>
    <section class="py-20 sm:py-32 bg-background-light relative overflow-hidden" data-section="blog-main">
        <!-- Subtle animated background pattern -->
        <div class="absolute inset-0 opacity-[0.02] pointer-events-none">
            <div class="blog-main-bg-pattern absolute inset-0"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <!-- Header -->
            <div class="text-center max-w-4xl mx-auto mb-16" data-reveal="fade-up" data-reveal-delay="100">
                <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-6">
                    Wiedza, która <span class="text-brand-blue">napędza</span> sukces
                </h1>
                <p class="text-xl text-text-muted leading-relaxed">
                    Praktyczne porady, aktualne przepisy i sprawdzone strategie dla placówek medycznych. 
                    Bądź na bieżąco z najnowszymi zmianami w systemie zdrowia.
                </p>
            </div>

            <!-- Categories Filter (if we have categories) -->
            {categories && categories.length > 0 && (
                <div class="flex flex-wrap justify-center gap-3 mb-12" data-reveal="fade-up" data-reveal-delay="200">
                    <a 
                        href="/blog" 
                        class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-brand-blue text-white transition-all hover:bg-brand-blue/90"
                    >
                        Wszystkie
                    </a>
                    {categories.slice(0, 5).map((category) => (
                        <a 
                            href={`/blog/category/${category.slug || category.name.toLowerCase().replace(/\s+/g, '-')}`}
                            class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-white text-text-muted border border-slate-200 transition-all hover:border-brand-blue hover:text-brand-blue"
                        >
                            {category.name}
                        </a>
                    ))}
                </div>
            )}

            <!-- Blog Posts Grid -->
            <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-8 mb-16">
                {posts.map((post, index) => {
                    // FIXED: Safe property access for union types
                    const author = post.author || { name: "Koordynuj Zdrowie" };
                    const category = typeof post.category === 'string' ? post.category : post.category?.name || "Artykuł";
                    
                    return (
                        <article 
                            class="blog-card group flex flex-col bg-white border border-slate-200/80 rounded-3xl shadow-sm transition-all duration-500 hover:border-brand-blue/50 hover:shadow-xl hover:shadow-brand-blue/10"
                            data-reveal="slide-up-scale"
                            data-reveal-delay={300 + (index * 100)}
                        >
                            {/* Featured Image - FIXED: Safe property access */}
                            <div class="aspect-[16/9] bg-gradient-to-br from-brand-blue/10 to-brand-blue/5 rounded-t-3xl overflow-hidden relative">
                                {post.featuredImage && post.featuredImage.url ? (
                                    <img 
                                        src={post.featuredImage.url} 
                                        alt={post.title}
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                    />
                                ) : (
                                    <div class="w-full h-full flex items-center justify-center">
                                        <svg class="w-16 h-16 text-brand-blue/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                        </svg>
                                    </div>
                                )}
                                
                                {/* Category Badge */}
                                <div class="absolute top-4 left-4">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-brand-blue/90 text-white">
                                        {category}
                                    </span>
                                </div>
                            </div>

                            {/* Card Content */}
                            <div class="flex flex-col flex-grow p-6">
                                
                                {/* Meta Info */}
                                <div class="flex items-center text-sm text-text-muted mb-3">
                                    <div class="flex items-center">
                                        <div class="w-6 h-6 bg-gradient-to-br from-brand-blue to-brand-blue/80 rounded-full flex items-center justify-center mr-2">
                                            <span class="text-white text-xs font-bold">
                                                {author.name?.charAt(0) || "K"}
                                            </span>
                                        </div>
                                        <span>{author.name}</span>
                                    </div>
                                    <span class="mx-2">•</span>
                                    {/* FIXED: Only use publishedAt property that exists in both union types */}
                                    <time>{formatDate(post.publishedAt ?? "")}</time>
                                </div>

                                {/* Title */}
                                <h2 class="text-xl font-bold text-text-primary mb-3 group-hover:text-brand-blue/90 transition-colors duration-300 line-clamp-2">
                                    {post.title}
                                </h2>

                                {/* Excerpt - FIXED: Only use excerpt property that exists in both types */}
                                <p class="text-text-muted leading-relaxed mb-4 flex-grow line-clamp-3">
                                    {post.excerpt || "Przeczytaj więcej w pełnym artykule..."}
                                </p>

                                {/* Read More Link */}
                                <a 
                                    href={`/blog/${post.slug}`}
                                    class="inline-flex items-center text-brand-blue font-semibold mt-auto group-hover:translate-x-1 transition-transform duration-300"
                                >
                                    Czytaj więcej
                                    <svg class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                    </svg>
                                </a>
                            </div>
                        </article>
                    );
                })}
            </div>

            <!-- Pagination */
            {totalPages > 1 && (
                <div class="flex justify-center" data-reveal="fade-up" data-reveal-delay="500">
                    <nav class="flex items-center space-x-2">
                        {currentPage > 1 && (
                            <a href={`/blog/page/${currentPage - 1}`} class="pagination-btn">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                                </svg>
                            </a>
                        )}
                        
                        {Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => (
                            <a 
                                href={pageNum === 1 ? '/blog' : `/blog/page/${pageNum}`}
                                class={`pagination-btn ${pageNum === currentPage ? 'active' : ''}`}
                            >
                                {pageNum}
                            </a>
                        ))}
                        
                        {currentPage < totalPages && (
                            <a href={`/blog/page/${currentPage + 1}`} class="pagination-btn">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                            </a>
                        )}
                    </nav>
                </div>
            )}

            <!-- Newsletter CTA -->
            <div class="mt-20 text-center" data-reveal="fade-up" data-reveal-delay="600">
                <div class="max-w-2xl mx-auto bg-gradient-to-br from-brand-blue/5 to-brand-blue/10 rounded-3xl p-8 border border-brand-blue/20">
                    <h3 class="text-2xl font-bold text-text-primary mb-4">
                        Nie przegap najnowszych artykułów!
                    </h3>
                    <p class="text-text-muted mb-6">
                        Otrzymuj powiadomienia o najnowszych publikacjach bezpośrednio na swoją skrzynkę e-mail.
                    </p>
                    <a href="/kontakt" class="btn-primary inline-flex items-center group">
                        Zapisz się na newsletter
                        <svg class="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    /* === CONSISTENT REVEAL SYSTEM === */
    [data-reveal] {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    
    [data-reveal="slide-up-scale"] {
        opacity: 0;
        transform: translateY(30px) scale(0.95);
    }
    
    [data-reveal].revealed {
        opacity: 1;
        transform: translateY(0);
    }
    
    [data-reveal="slide-up-scale"].revealed {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    /* === BLOG CARDS - IDENTICAL TO OTHER SECTIONS === */
    .blog-card {
        position: relative;
        cursor: pointer;
    }
    
    .blog-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 1.5rem;
        background: linear-gradient(135deg, rgba(0, 169, 224, 0.05), rgba(0, 169, 224, 0.02));
        opacity: 0;
        transition: opacity 0.5s ease;
    }
    
    .blog-card:hover::before {
        opacity: 1;
    }
    
    .blog-card:hover {
        transform: translateY(-4px);
    }

    /* === PAGINATION STYLING === */
    .pagination-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 2.5rem;
        height: 2.5rem;
        padding: 0.5rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        font-weight: 500;
        color: #64748b;
        background: white;
        transition: all 0.2s;
        text-decoration: none;
    }
    
    .pagination-btn:hover {
        border-color: var(--color-brand-blue);
        color: var(--color-brand-blue);
        transform: translateY(-1px);
    }
    
    .pagination-btn.active {
        background: var(--color-brand-blue);
        border-color: var(--color-brand-blue);
        color: white;
    }

    /* === LINE CLAMP UTILITIES === */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* === SUBTLE BACKGROUND PATTERN === */
    .blog-main-bg-pattern {
        background-image: 
            radial-gradient(circle at 25% 25%, rgba(0, 169, 224, 0.08) 1px, transparent 1px),
            radial-gradient(circle at 75% 75%, rgba(0, 169, 224, 0.06) 1px, transparent 1px),
            radial-gradient(circle at 50% 50%, rgba(0, 169, 224, 0.10) 1px, transparent 1px);
        background-size: 150px 150px, 200px 200px, 180px 180px;
        animation: patternFloat 40s linear infinite;
    }

    /* === KEYFRAME ANIMATIONS === */
    @keyframes patternFloat {
        0% {
            background-position: 0% 0%, 0% 0%, 0% 0%;
        }
        100% {
            background-position: 100% 100%, -100% 100%, 50% -100%;
        }
    }

    /* === ACCESSIBILITY & PERFORMANCE === */
    
    /* Fallback: show elements if JS doesn't load */
    .no-js [data-reveal] {
        opacity: 1 !important;
        transform: none !important;
    }
    
    @media (prefers-reduced-motion: reduce) {
        [data-reveal],
        .blog-card,
        .blog-main-bg-pattern {
            animation: none !important;
            transition: none !important;
        }
        
        [data-reveal] {
            opacity: 1;
            transform: none;
        }
    }
    
    @media (max-width: 768px) {
        .blog-main-bg-pattern {
            display: none; /* Better mobile performance */
        }
    }
</style>

<script>
    // BLOG MAIN PAGE ANIMATION CONTROLLER
    document.addEventListener('DOMContentLoaded', () => {
        const blogMainSection = document.querySelector('[data-section="blog-main"]') as HTMLElement;
        if (!blogMainSection) return;

        // FALLBACK: Show elements after 2s if they're still hidden
        setTimeout(() => {
            const hiddenElements = blogMainSection.querySelectorAll('[data-reveal]:not(.revealed)');
            hiddenElements.forEach(el => el.classList.add('revealed'));
        }, 2000);

        // INTERSECTION OBSERVER - PERFORMANCE OPTIMIZED
        const observerOptions: IntersectionObserverInit = {
            rootMargin: '50px 0px -100px 0px', // Start animation slightly before entering viewport
            threshold: [0, 0.1]
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                const element = entry.target as HTMLElement;
                
                if (entry.isIntersecting && entry.intersectionRatio > 0) {
                    // Add delay from data attribute
                    const delay = parseInt(element.dataset.revealDelay || '0');
                    
                    setTimeout(() => {
                        element.classList.add('revealed');
                    }, delay);
                    
                    // Stop observing once revealed for performance
                    observer.unobserve(element);
                }
            });
        }, observerOptions);

        // Observe all reveal elements within this section
        const revealElements = blogMainSection.querySelectorAll('[data-reveal]');
        revealElements.forEach(el => observer.observe(el));

        // CLEANUP: Disconnect observer when section is removed (if using frameworks)
        const cleanup = () => observer.disconnect();
        
        // Handle page visibility changes for performance
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                observer.disconnect();
            } else if (revealElements.length > 0) {
                revealElements.forEach(el => {
                    if (!el.classList.contains('revealed')) {
                        observer.observe(el);
                    }
                });
            }
        });

        return cleanup;
    });
</script>