---
// src/components/layout/Footer.astro - FINAL, ENHANCED VERSION
import Logo from '../ui/Logo.astro';
import AnimateOnScroll from '../ui/AnimateOnScroll.astro';

const mainNavLinks = [
    { href: '#problemy', label: 'Diagnoza' },
    { href: '#oferta', label: 'Oferta' },
    { href: '#dowod', label: 'Rezultaty' },
    { href: '#proces', label: 'Proces' },
];

const secondaryNavLinks = [
    { href: '/blog', label: 'Blog' },
    { href: '#', label: 'Polityka Prywatności' }, // Placeholder
    { href: '#', label: 'Regulamin' }, // Placeholder
];
---

<footer class="bg-background-muted border-t border-slate-200/80 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none">
        <div class="footer-bg-pattern absolute inset-0"></div>
    </div>
    
    <AnimateOnScroll>
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                
                <div class="lg:col-span-4">
                    <a href="/" aria-label="Strona główna">
                        <Logo />
                    </a>
                    <p class="mt-6 text-text-muted text-sm leading-relaxed max-w-xs">
                        Zarządzanie medycyną zredukowane do perfekcji. Podnosimy efektywność i bezpieczeństwo prawne placówek medycznych w Polsce.
                    </p>
                    <div class="flex space-x-4 mt-8">
                        <a href="#" class="social-link group" aria-label="LinkedIn">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                        </a>
                    </div>
                </div>

                <div class="lg:col-span-8 grid grid-cols-2 md:grid-cols-3 gap-8">
                    <div>
                        <h4 class="footer-heading">Mapa Strony</h4>
                        <ul class="mt-4 space-y-3">
                            {mainNavLinks.map(link => (
                                <li>
                                    <a href={link.href} class="footer-link">
                                        {link.label}
                                    </a>
                                </li>
                            ))}
                            <li><a href="#kontakt" class="footer-link">Kontakt</a></li>
                        </ul>
                    </div>

                    <div>
                        <h4 class="footer-heading">Informacje</h4>
                        <ul class="mt-4 space-y-3">
                             {secondaryNavLinks.map(link => (
                                <li>
                                    <a href={link.href} class="footer-link">
                                        {link.label}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>

                    <div>
                        <h4 class="footer-heading">Skontaktuj się</h4>
                        <ul class="mt-4 space-y-3">
                            <li>
                                <a href="mailto:kontakt@koordynujzdrowie.pl" class="footer-link group inline-flex items-center">
                                    <svg class="w-4 h-4 mr-2 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                    Napisz do nas
                                </a>
                            </li>
                            <li>
                                <a href="tel:+48123456789" class="footer-link group inline-flex items-center">
                                     <svg class="w-4 h-4 mr-2 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                    Zadzwoń
                                </a>
                            </li>
                            <li class="text-base text-text-muted pt-2">
                                Lublin, Polska
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="mt-16 sm:mt-24 pt-8 border-t border-slate-200/80 text-center">
                <p class="text-sm text-text-muted">
                    &copy; {new Date().getFullYear()} Koordynuj Zdrowie. Wszelkie prawa zastrzeżone.
                </p>
            </div>
        </div>
    </AnimateOnScroll>
</footer>

<style>
    .footer-heading {
        font-size: 0.875rem; /* text-sm */
        font-weight: 600; /* semibold */
        color: var(--color-text-primary);
        letter-spacing: 0.05em; /* tracking-wider */
        text-transform: uppercase;
    }
    .footer-link {
        font-size: 1rem; /* text-base */
        color: var(--color-text-muted);
        transition: color 0.2s ease-out, transform 0.2s ease-out;
        display: inline-block;
    }
    .footer-link:hover {
        color: var(--color-brand-blue);
        transform: translateX(2px);
    }
    .social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem; /* w-10 */
        height: 2.5rem; /* h-10 */
        border-radius: 9999px; /* rounded-full */
        background-color: hsl(var(--color-text-primary-hsl) / 0.05);
        color: var(--color-text-muted);
        transition: all 0.2s ease-out;
    }
    .social-link:hover {
        color: white;
        background-color: var(--color-brand-blue);
        transform: translateY(-2px) scale(1.05);
    }
    .footer-bg-pattern {
        background-image: 
            radial-gradient(circle at 10% 90%, rgba(0, 169, 224, 0.1) 1px, transparent 1px),
            radial-gradient(circle at 90% 10%, rgba(0, 169, 224, 0.08) 1px, transparent 1px);
        background-size: 200px 200px, 150px 150px;
        animation: patternDrift 45s linear infinite;
    }
    @keyframes patternDrift {
        0% { background-position: 0% 0%, 0% 0%; }
        100% { background-position: -100% 100%, 100% -100%; }
    }
</style>